# MCP Servers
GITHUB_PERSONAL_ACCESS_TOKEN=
STACK_EXCHANGE_API_KEY=
FIGMA_API_KEY=
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
SONARQUBE_TOKEN=
SONARQUBE_URL=

# Plugins
OPENCODE_MEM_USER_EMAIL=
OPENCODE_MEM_USER_NAME=

# Model Configuration
# Default model for OpenCode (must be in format: provider/model-id)
# Examples:
#   - amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0
#   - openai/gpt-4o
#   - ollama/qwen2.5-coder:7b-instruct
OPENCODE_MODEL=amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0
# Small model for quick tasks (fallback if not set: uses OPENCODE_MODEL)
OPENCODE_SMALL_MODEL=amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0

# Amazon Bedrock Provider (https://opencode.ai/docs/providers#amazon-bedrock)
# AWS region for Bedrock (defaults to us-east-1 if not set)
AWS_REGION=
# AWS named profile from ~/.aws/credentials (defaults to default profile if not set)
AWS_PROFILE=
# Optional: Bearer token for Bedrock (takes precedence over profile-based auth)
# AWS_BEARER_TOKEN_BEDROCK=
